{
  "name": "@autopoly/managed-trading",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./src/polymarket-adapter.ts",
      "import": "./dist/polymarket-adapter.js",
      "default": "./dist/polymarket-adapter.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@autopoly/contracts": "workspace:*",
    "@autopoly/db": "workspace:*",
    "@polymarket/builder-relayer-client": "^0.0.9",
    "@polymarket/clob-client": "^5.8.1",
    "@polymarket/clob-client-v2": "1.0.6",
    "dotenv": "17.2.3",
    "drizzle-orm": "0.45.1",
    "ethers": "5.7.2",
    "viem": "2.31.0"
  }
}
